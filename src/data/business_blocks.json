[
  {
    "block_id": "web_scraper_core",
    "name": "🕷️ 網路爬蟲核心積木 (Scrapling)",
    "strategy": "TOOL_CALL",
    "handoff_policy": "enrich_and_return",
    "used_by": [
      "brain:real_estate_analyst_v1",
      "brain:scrapling_commander_v1",
