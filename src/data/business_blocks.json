      "brain:growth_hacker_v1",
      "brain:seo_specialist",
      "brain:legal_advisor_pro",
      "brain:ceo_strategist"
    ],
    "tools": [
      {
        "name": "scrape_static",
        "endpoint": "http://localhost:8088/scrape",
        "mode": "static",
        "description": "快速抓取靜態頁面，適合無反爬機制的政府或新聞網站"
      },
      {
        "name": "scrape_stealthy",
        "endpoint": "http://localhost:8088/scrape",
        "mode": "stealthy",
        "description": "隱匿模式，用於有 Cloudflare 防護的租屋、購物平台"
      },
      {
        "name": "scrape_dynamic",
        "endpoint": "http://localhost:8088/scrape",
        "mode": "dynamic",
        "description": "完整瀏覽器模式，處理 SPA 與需要 JavaScript 執行的頁面"
      },
      {
        "name": "scrape_batch",
        "endpoint": "http://localhost:8088/scrape/batch",
        "mode": "stealthy",
        "description": "批次爬取多個 URL，適合 Multica Cron 定時任務"
      }
    ],
    "rules": [
      "優先使用 scrape_static，只有靜態失效才升級到 stealthy",
      "回傳 Markdown 格式，去除廣告與導航列",
      "每個域名最高 3 req/s，遵守合理爬取間隔",
      "爬取結果必須標注來源 URL 與時間戳記"
    ],
    "wiki": "docs/web-scraper-playbook.md",
    "bd_value": "critical",
    "fallback": ["inform_user_of_scrape_failure"]
  },
